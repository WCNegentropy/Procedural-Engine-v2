# Include essential files
include README.md
include AGENTS.md
include LICENSE
include pyproject.toml
include setup.py
include requirements.txt

# Include main entry point
include main.py

# Include C++ sources for building extension module
recursive-include cpp *.cpp *.h *.hpp
include cpp/CMakeLists.txt

# Include procengine package (core Python modules)
recursive-include procengine *.py

# Include game data files
recursive-include data *.json

# Include documentation
recursive-include docs *.md

# Include examples
recursive-include examples *.py

# Include tools
recursive-include tools *.py

# Include PyInstaller spec for standalone builds
include ProceduralEngine.spec

# Include build scripts
recursive-include scripts *.sh *.bat

# Exclude build artifacts and caches
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude *.pyd
global-exclude *.dylib
global-exclude .git*
global-exclude .DS_Store

# Exclude test files from sdist (tests are in tests/ directory)
prune tests
prune Legacy

# Exclude build directories
prune build
prune dist
prune *.egg-info
